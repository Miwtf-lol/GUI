-- notification function
local function Notify(text)
	local n = Instance.new("TextLabel")
	n.Parent = ScreenGui
	n.Size = UDim2.new(0, 200, 0, 40)
	n.Position = UDim2.new(1, -210, 1, -60)
	n.BackgroundColor3 = Color3.fromRGB(30,30,30)
	n.TextColor3 = Color3.fromRGB(255,255,255)
	n.Text = text
	n.Font = Enum.Font.GothamBold
	n.TextSize = 14
	
	Instance.new("UICorner", n).CornerRadius = UDim.new(0,8)

	-- fade in
	n.BackgroundTransparency = 1
	n.TextTransparency = 1
	game:GetService("TweenService"):Create(n, TweenInfo.new(0.3), {
		BackgroundTransparency = 0,
		TextTransparency = 0
	}):Play()

	-- auto remove
	game:GetService("Debris"):AddItem(n, 2)
end

