-- TOGGLE
local function createToggle(parent, text, y, callback)
    local label = Instance.new("TextLabel", parent)
    label.Text = text
    label.Position = UDim2.new(0,15,0,y)
    label.Size = UDim2.new(1,-80,0,25)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(220,220,220)
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left

    local toggle = Instance.new("TextButton", parent)
    toggle.Size = UDim2.new(0,50,0,25)
    toggle.Position = UDim2.new(1,-60,0,y)
    toggle.BackgroundColor3 = Color3.fromRGB(60,60,60)
    toggle.Text = ""
    toggle.Font = Enum.Font.GothamBold
    local toggleCorner = Instance.new("UICorner", toggle)
    toggleCorner.CornerRadius = UDim.new(0,12)
    
    local circle = Instance.new("Frame", toggle)
    circle.Size = UDim2.new(0,20,0,20)
    circle.Position = UDim2.new(0,2.5,0,2.5)
    circle.BackgroundColor3 = Color3.fromRGB(200,200,200)
    circle.BorderSizePixel = 0
    local circleCorner = Instance.new("UICorner", circle)
    circleCorner.CornerRadius = UDim.new(0,10)
    
    local enabled = false
    local connection
    toggles[text] = {enabled = false, set = function(state) 
        enabled = state
        local targetColor = enabled and Color3.fromRGB(0,170,255) or Color3.fromRGB(60,60,60)
        local targetCircleColor = enabled and Color3.fromRGB(255,255,255) or Color3.fromRGB(200,200,200)
        local targetPos = enabled and UDim2.new(1,-22.5,0,2.5) or UDim2.new(0,2.5,0,2.5)
        
        TS:Create(toggle, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        TS:Create(circle, TweenInfo.new(0.2), {BackgroundColor3 = targetCircleColor, Position = targetPos}):Play()
        if callback then callback(enabled) end
    end}
    
    toggle.MouseButton1Click:Connect(function()
        enabled = not enabled
        toggles[text].set(enabled)
    end)
    
    return toggles[text]
end

-- SLIDER
local function createSlider(parent, text, y, min, max, default, callback)
    local label = Instance.new("TextLabel", parent)
    label.Text = text.." ["..default.."]"
    label.Position = UDim2.new(0,15,0,y)
    label.Size = UDim2.new(1,-70,0,25)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(220,220,220)
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left

    local bar = Instance.new("Frame", parent)
    bar.Size = UDim2.new(0,200,0,8)
    bar.Position = UDim2.new(1,-220,0,y+28)
    bar.BackgroundColor3 = Color3.fromRGB(50,50,50)
    bar.BorderSizePixel = 0
    local barCorner = Instance.new("UICorner", bar)
    barCorner.CornerRadius = UDim.new(0,4)

    local fill = Instance.new("Frame", bar)
    fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(0,170,255)
    fill.BorderSizePixel = 0
    local fillCorner = Instance.new("UICorner", fill)
    fillCorner.CornerRadius = UDim.new(0,4)
    
    local draggingSlider = false
    sliders[text] = {value = default, set = function(val)
        local percent = (val-min)/(max-min)
        fill.Size = UDim2.new(percent,0,1,0)
        label.Text = text.." ["..math.floor(val).."]"
        if callback then callback(val) end
    end}
    
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = true
        end
    end)
    
    bar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = false
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local percent = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
            local value = math.floor(min + (max - min) * percent)
            sliders[text].set(value)
        end
    end)
    
    return sliders[text]
end

