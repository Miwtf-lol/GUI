local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- GUI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "ChromaStyleUI"

-- MAIN
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 700, 0, 400)
main.Position = UDim2.new(0.5, -350, 0.5, -200)
main.BackgroundColor3 = Color3.fromRGB(20,20,20)
main.BackgroundTransparency = 0.15
main.BorderSizePixel = 0

Instance.new("UICorner", main).CornerRadius = UDim.new(0,12)

-- SIDEBAR
local sidebar = Instance.new("Frame", main)
sidebar.Size = UDim2.new(0, 200, 1, 0)
sidebar.BackgroundColor3 = Color3.fromRGB(15,15,15)
sidebar.BorderSizePixel = 0
Instance.new("UICorner", sidebar)

-- TITLE
local title = Instance.new("TextLabel", sidebar)
title.Text = "Chroma Hub Blade Ball V1"
title.Size = UDim2.new(1,0,0,50)
title.TextColor3 = Color3.fromRGB(255,255,255)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.TextSize = 14

-- TAB LIST
local tabs = {"Blatant","Detection","Farm","Misc","Exclusive","Creator"}
local buttons = {}

for i,tab in ipairs(tabs) do
    local btn = Instance.new("TextButton", sidebar)
    btn.Size = UDim2.new(1, -20, 0, 40)
    btn.Position = UDim2.new(0,10,0,60 + (i-1)*45)
    btn.Text = tab
    btn.BackgroundColor3 = Color3.fromRGB(25,25,25)
    btn.TextColor3 = Color3.fromRGB(200,200,200)
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn)
    
    buttons[tab] = btn
end

-- CONTENT
local content = Instance.new("Frame", main)
content.Size = UDim2.new(1, -210, 1, -20)
content.Position = UDim2.new(0, 210, 0, 10)
content.BackgroundTransparency = 1

-- CARD FUNCTION
local function createCard(titleText, yPos)
    local card = Instance.new("Frame", content)
    card.Size = UDim2.new(0, 220, 0, 150)
    card.Position = UDim2.new(0, 20, 0, yPos)
    card.BackgroundColor3 = Color3.fromRGB(30,30,30)
    card.BorderSizePixel = 0
    Instance.new("UICorner", card)

    local title = Instance.new("TextLabel", card)
    title.Text = titleText
    title.Size = UDim2.new(1,0,0,30)
    title.BackgroundTransparency = 1
    title.TextColor3 = Color3.white
    title.Font = Enum.Font.GothamBold
    title.TextSize = 14

    return card
end

-- TOGGLE FUNCTION
local function createToggle(parent, text, y)
    local label = Instance.new("TextLabel", parent)
    label.Text = text
    label.Position = UDim2.new(0,10,0,y)
    label.Size = UDim2.new(0,150,0,20)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(200,200,200)
    label.Font = Enum.Font.Gotham
    label.TextSize = 12

    local toggle = Instance.new("TextButton", parent)
    toggle.Size = UDim2.new(0,40,0,20)
    toggle.Position = UDim2.new(1,-50,0,y)
    toggle.BackgroundColor3 = Color3.fromRGB(60,60,60)
    toggle.Text = ""
    toggle.BorderSizePixel = 0
    Instance.new("UICorner", toggle)

    local enabled = false

    toggle.MouseButton1Click:Connect(function()
        enabled = not enabled
        toggle.BackgroundColor3 = enabled and Color3.fromRGB(0,170,255) or Color3.fromRGB(60,60,60)
    end)
end

-- SAMPLE TAB CONTENT
local blatCard = createCard("Parry", 20)
createToggle(blatCard, "Auto Parry", 40)
createToggle(blatCard, "Random Accuracy", 70)

local spamCard = createCard("Spam", 20)
spamCard.Position = UDim2.new(0,260,0,20)
createToggle(spamCard, "Auto Spam", 40)

-- TAB SWITCH
for name,btn in pairs(buttons) do
    btn.MouseButton1Click:Connect(function()
        for _,v in pairs(content:GetChildren()) do
            v.Visible = false
        end

        for _,v in pairs(content:GetChildren()) do
            v.Visible = true -- demo (bạn sẽ tách sau)
        end
    end)
end

-- DRAG (mobile)
local UIS = game:GetService("UserInputService")
local dragging, dragStart, startPos

main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)
