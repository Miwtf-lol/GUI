local dragging, dragStart, startPos, minimized = false, nil, nil, false

local function minimize()
    minimized = not minimized
    local targetSize = minimized and UDim2.new(0, 700, 0, 60) or UDim2.new(0, 700, 0, 420)
    local targetPosY = minimized and 0.02 or 0.5
    
    content.Visible = not minimized
    sidebar.Visible = not minimized
    title.Text = minimized and "VM.wtf | Click to expand" or "VM.wtf | Blade Ball"
    minimizeBtn.Text = minimized and "+" or "−"
    
    TS:Create(main, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {
        Size = targetSize,
        Position = UDim2.new(0.5, -350, targetPosY, minimized and 20 or -210)
    }):Play()
end

minimizeBtn.MouseButton1Click:Connect(minimize)
closeBtn.MouseButton1Click:Connect(function() gui:Destroy() end)

main.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not minimizeBtn:IsAncestorOf(input.Target) and not closeBtn:IsAncestorOf(input.Target) then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

