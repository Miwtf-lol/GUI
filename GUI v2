    minimized = not minimized
    local targetSize = minimized and UDim2.new(0, 650, 0, 50) or UDim2.new(0, 650, 0, 380)
    local targetPos = minimized and UDim2.new(0.5, -325, 0, 10) or UDim2.new(0.5, -325, 0.5, -190)
    
    content.Visible = not minimized
    sidebar.Visible = not minimized
    minimizeBtn.Text = minimized and "+" or "−"
    
    TS:Create(main, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = targetSize, Position = targetPos}):Play()
end)

main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- CORE FEATURES IMPLEMENTATION
local ball = workspace:WaitForChild("Balls", 10):WaitForChild("ball")
local connections = {}

local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local myPos = player.Character and player.Character.PrimaryPart.Position
    
    if not myPos then return nil end
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character.PrimaryPart then
            local distance = (myPos - otherPlayer.Character.PrimaryPart.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestPlayer = otherPlayer
            end
        end
    end
    return closestPlayer
end

local function fireParryServer()
    local args = {
        [1] = workspace.Balls.ball,
        [2] = player.Character.PrimaryPart,
        [3] = game.Players.LocalPlayer.Character.PrimaryPart.CFrame,
        [4] = workspace.Balls.ball.AssemblyLinearVelocity
    }
    game:GetService("ReplicatedStorage").MainEvent:FireServer(unpack(args))
end

local function spamClick()
    if settings.autoSpam and tick() % 0.1 < settings.spamThreshold then
        mouse1click()
        mouse1release()
    end
end

-- AUTO PARRY LOOP
connections.parry = RS.Heartbeat:Connect(function()
    if not settings.autoParry or not player.Character or not player.Character.PrimaryPart then return end
    
    local ballVelocity = ball.AssemblyLinearVelocity
    local ballPos = ball.Position
    local playerPos = player.Character.PrimaryPart.Position
    
    local distance = (ballPos - playerPos).Magnitude
    local timeToHit = distance / ballVelocity.Magnitude
    
    if distance < 50 and timeToHit < 0.5 and math.random() < settings.parryAccuracy then
        fireParryServer()
    end
end)

-- AUTO SPAM LOOP
connections.spam = RS.Heartbeat:Connect(spamClick)

