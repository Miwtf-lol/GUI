-- Auto Parry
local parryConnection
parryConnection = RS.Heartbeat:Connect(function()
    if not settings.autoParry or not ball or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    
    myHumanoidRootPart = player.Character.HumanoidRootPart
    local ballPos = ball.Position
    local myPos = myHumanoidRootPart.Position
    local distance = (ballPos - myPos).Magnitude
    
    if distance < 60 then
        local direction = (myPos - ballPos).Unit
        local dotProduct = camera.CFrame.LookVector:Dot(direction)
        
        if dotProduct > (1 - settings.parryAccuracy) and math.random() < settings.parryAccuracy / 100 then
            local args = {
                [1] = ball,
                [2] = myHumanoidRootPart,
                [3] = myHumanoidRootPart.CFrame,
                [4] = ball.AssemblyLinearVelocity
            }
            pcall(function()
                game:GetService("ReplicatedStorage").MainEvent:FireServer(unpack(args))
            end)
        end
    end
end)

